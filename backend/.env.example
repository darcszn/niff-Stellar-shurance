# Backend Environment Variables
# Copy to .env and update values

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/niffyinsure?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=niff_user
DB_PASSWORD=niff_password
DB_NAME=niff_stellar

# Redis
REDIS_URL=redis://localhost:6379/0

# Soroban RPC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract
CONTRACT_ID=
# Default SEP-41 token contract used when no per-policy asset is specified.
# Must match the token passed to initialize() on the contract.
DEFAULT_TOKEN_CONTRACT_ID=
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# IPFS Configuration
# Provider: mock | pinata
IPFS_PROVIDER=mock
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
IPFS_MAX_FILE_SIZE=52428800
IPFS_MIN_FILE_SIZE=1
IPFS_STRIP_EXIF=true

# Auth
JWT_SECRET=super-secret-jwt-key-change-in-prod
JWT_EXPIRES_IN=7d
ADMIN_TOKEN=admin-token-for-cli

# CORS
# Comma-separated list of approved public frontend origins.
# Local dev: use your Next.js dev server origin (e.g. http://localhost:3001).
# Multiple origins: FRONTEND_ORIGINS=https://app.example.com,https://www.example.com
# Production: all entries MUST start with https:// — http:// and wildcard * are rejected at startup.
# Mobile app origins: add them here as additional comma-separated entries when needed.
FRONTEND_ORIGINS=http://localhost:3001
# Comma-separated list of allowed origins for the admin UI (optional, separate from public).
# Leave empty if there is no separate admin UI.
ADMIN_CORS_ORIGINS=http://localhost:3002

# Staff Auth (required in non-production)
DEFAULT_ADMIN_EMAIL=admin@niffyinsure.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_SUPPORT_EMAIL=support@niffyinsure.com
DEFAULT_SUPPORT_PASSWORD=

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# Logging
LOG_LEVEL=info

# Cache
CACHE_TTL_SECONDS=60

# CAPTCHA (Turnstile or hCaptcha)
# Provider: turnstile | hcaptcha
CAPTCHA_PROVIDER=turnstile
# Set to 'dev-skip' to bypass verification in development
CAPTCHA_SECRET_KEY=dev-skip
CAPTCHA_SITE_KEY=

# Support
IP_HASH_SALT=change-me-in-production

# -----------------------------------------------------------------------------
# On-Ramp (owner: product team — legal review required per region before enabling)
# -----------------------------------------------------------------------------
# Feature flag: set FEATURE_FLAGS_JSON={"ramp":true} to enable
# Third-party ramp base URL (no wallet addresses — UTM params appended automatically)
RAMP_URL=
# Comma-separated ISO 3166-1 alpha-2 region codes where ramp is permitted.
# Leave empty to allow all regions (not recommended without legal review).
RAMP_ALLOWED_REGIONS=
# UTM parameters (optional overrides)
RAMP_UTM_SOURCE=niffyinsure
RAMP_UTM_MEDIUM=app
RAMP_UTM_CAMPAIGN=onramp
