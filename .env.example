# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.
#
# CONVENTION:
#   NEXT_PUBLIC_*  → safe to expose in the browser bundle
#   (no prefix)    → server-only; NEVER import in client components
#                    use `import '@/lib/server-guard'` to enforce this

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Minimum 32 random characters in production
REDIS_PASSWORD=devpassword
# Set to "true" and configure TLS certs for production managed Redis
REDIS_TLS=false

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
